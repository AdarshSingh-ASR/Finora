# Primary AI provider. Paste service-account JSON on one line or base64 encode it.
GOOGLE_VERTEX_CREDENTIALS=
GOOGLE_VERTEX_LOCATION=global
GOOGLE_VERTEX_MODEL=gemini-2.5-flash

# Automatic text fallback
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
FINORA_DATA_DIR=.finora

# Better Auth + Google sign-in
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Protects POST /api/reports/weekly from unauthorised callers
CRON_SECRET=
